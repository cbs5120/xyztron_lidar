#!/usr/bin/env python3
# -*- coding: utf-8 -*- 1
#=============================================
# 본 프로그램은 자이트론에서 제작한 것입니다.
# 상업라이센스에 의해 제공되므로 무단배포 및 상업적 이용을 금합니다.
# 교육과 실습 용도로만 사용가능하며 외부유출은 금지됩니다.
#=============================================
import rclpy, time, cv2, os, math
import numpy as np
from rclpy.node import Node
from xycar_msgs.msg import XycarMotor
from sensor_msgs.msg import Image
from sensor_msgs.msg import LaserScan
from rclpy.qos import qos_profile_sensor_data
from rclpy.duration import Duration
from cv_bridge import CvBridge

#=============================================
# ROS2 Node 클래스 정의
#=============================================
class TrackDriverNode(Node):

    #=============================================
    # 클래스 생성 초기화 함수
    #=============================================
    def __init__(self):

        super().__init__('driver')
        self.get_logger().info('----- Xycar self-driving node started -----')
        
        # 상수값 및 초기값 설정
        self.image = None  # 카메라 토픽 데이터를 저장할 변수
        self.motor_msg = XycarMotor()  # 모터토픽 메시지        
        self.lidar_ranges = None
        self.bridge = CvBridge()
        
        # ROS2 Publisher & Subscriber 설정
        self.motor_pub = self.create_publisher(XycarMotor,'xycar_motor',10)
        
        self.sub_front = self.create_subscription(
            Image, '/usb_cam/image_raw/front', self.cam_callback, qos_profile_sensor_data)

        self.subscription = self.create_subscription(
            LaserScan, '/scan', self.lidar_callback, qos_profile_sensor_data)
		
        self.get_logger().info("Track Driver Node Initialized")
              
    #=============================================
    # 카메라 토픽을 수신하는 콜백 함수
    #=============================================
    def cam_callback(self, data):
        # 수신한 메시지를 OpenCV 이미지로 변환하여 저장
        self.image = self.bridge.imgmsg_to_cv2(data, "bgr8")
    
    #=============================================
    # 라이다 토픽을 수신하는 콜백 함수
    #=============================================
    def lidar_callback(self, msg):
        self.lidar_ranges = msg.ranges   
      
    #=============================================
    # 모터제어 토픽을 발행하는 Publisher 함수
    #=============================================
    def drive(self, angle, speed):
        self.motor_msg.angle = float(angle)
        self.motor_msg.speed = float(speed)
        self.motor_pub.publish(self.motor_msg)

    #=============================================
    # 메인 루프
    #=============================================
    def main_loop(self):

        self.get_logger().info("======================================")
        self.get_logger().info("  W A I T I N G   S I G N A L ...     ")
        self.get_logger().info("======================================")

        green_count = 0
        green_confirm_count = 5   # 초록불이 3프레임 연속 보이면 출발

        # 1단계: 초록불이 나올 때까지 정지
        while rclpy.ok():

            # 중요: 이 코드가 있어야 cam_callback이 실행되어 self.image가 갱신됨
            rclpy.spin_once(self, timeout_sec=0.01)

            if self.is_green_light():
                green_count += 1
                self.get_logger().info(f"Green detected: {green_count}")
            else:
                green_count = 0

            if green_count >= green_confirm_count:
                self.get_logger().info("GREEN LIGHT! Start driving.")
                break

            self.drive(angle=0, speed=0)
            time.sleep(0.05)

        # 2단계: 출발 후 주행
        while rclpy.ok():

            rclpy.spin_once(self, timeout_sec=0.01)

            self.drive(angle=0, speed=8)
            time.sleep(0.05)

    #=============================================
    # 초록불 감지 함수
    #=============================================
    def is_green_light(self):
        if self.image is None:
            return False

        frame = self.image.copy()
        h, w = frame.shape[:2]

        # 신호등 전체 영역: 화면 위쪽 중앙
        traffic_roi = frame[int(h * 0.18):int(h * 0.52),
                            int(w * 0.25):int(w * 0.75)]

        if traffic_roi.size == 0:
            return False

        roi_h, roi_w = traffic_roi.shape[:2]

        # 오른쪽 초록불 영역만 사용
        roi = traffic_roi[:, int(roi_w * 0.60):roi_w]

        hsv = cv2.cvtColor(roi, cv2.COLOR_BGR2HSV)

        # =========================================
        # 신호등은 보통 왼쪽=빨강, 가운데=노랑, 오른쪽=초록
        # 따라서 오른쪽 1/3 영역만 초록불 검사
        # =========================================
        green_roi = traffic_roi[:, int(roi_w * 0.45):roi_w]

        # 빨간불 영역도 같이 확인해서 오검출 방지
        red_roi = traffic_roi[:, 0:int(roi_w * 0.38)]

        green_hsv = cv2.cvtColor(green_roi, cv2.COLOR_BGR2HSV)
        red_hsv = cv2.cvtColor(red_roi, cv2.COLOR_BGR2HSV)

        # 초록불 범위: 너무 넓게 잡지 않음
        lower_green = np.array([35, 50, 50])
        upper_green = np.array([95, 255, 255])
        green_mask = cv2.inRange(green_hsv, lower_green, upper_green)

        # 빨간불 범위: HSV에서 빨강은 양쪽 끝 범위 사용
        lower_red1 = np.array([0, 80, 80])
        upper_red1 = np.array([10, 255, 255])
        lower_red2 = np.array([170, 80, 80])
        upper_red2 = np.array([179, 255, 255])

        red_mask1 = cv2.inRange(red_hsv, lower_red1, upper_red1)
        red_mask2 = cv2.inRange(red_hsv, lower_red2, upper_red2)
        red_mask = red_mask1 + red_mask2

        kernel = np.ones((5, 5), np.uint8)

        green_mask = cv2.morphologyEx(green_mask, cv2.MORPH_OPEN, kernel)
        green_mask = cv2.morphologyEx(green_mask, cv2.MORPH_DILATE, kernel)

        red_mask = cv2.morphologyEx(red_mask, cv2.MORPH_OPEN, kernel)
        red_mask = cv2.morphologyEx(red_mask, cv2.MORPH_DILATE, kernel)

        green_area = cv2.countNonZero(green_mask)
        red_area = cv2.countNonZero(red_mask)

        self.get_logger().info(
            f"green_area={green_area}, red_area={red_area}"
        )

        # 디버깅 창
        cv2.imshow("traffic_roi", traffic_roi)
        cv2.imshow("green_roi", green_roi)
        cv2.imshow("green_mask", green_mask)
        cv2.waitKey(1)

        # =========================================
        # 출발 조건
        # 1. 초록 영역이 충분히 커야 함
        # 2. 빨간 영역이 거의 없어야 함
        # =========================================
        if green_area > 120 and red_area < 60:
            return True
        else:
            return False
#=============================================
# 메인 함수
#=============================================
def main(args=None):
    rclpy.init(args=args)
    node = TrackDriverNode()

    try:
        node.main_loop()
    except KeyboardInterrupt:
        pass
    finally:
        node.drive(angle=0, speed=0)
        cv2.destroyAllWindows()
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()
